# Server (used by systemd / local uvicorn)
HOST=0.0.0.0
PORT=8000

# Public HTTPS hostname (set by scripts/setup-ssl.sh)
# PATRO_API_DOMAIN=84-235-248-118.sslip.io

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Extra CORS origins (merged with built-in defaults: dpatro.vercel.app, GitHub Pages, localhost)
CORS_ALLOW_ORIGINS=https://sushilldhakal.github.io

# Warm holiday cache on startup (true/false)
PRECOMPUTE_ON_STARTUP=true

# BS years to precompute on startup, e.g. 2082,2083,2084
# PRECOMPUTE_BS_YEARS=

# Years before/after current BS year when PRECOMPUTE_BS_YEARS is unset
PRECOMPUTE_BS_SPAN=1

# ─── Auth / user accounts ───────────────────────────────────────────────────────
# When DATABASE_URL is unset the auth/profile routes are simply disabled and the
# panchanga API keeps working unchanged.
#
# PostgreSQL on this same server (recommended). Create the DB/user first — see
# deploy/AUTH_SETUP.md.
# DATABASE_URL=postgresql+psycopg://patro:CHANGE_ME@127.0.0.1:5432/patro

# Secret used to sign access/refresh tokens. Generate with:  openssl rand -hex 32
# JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30

# Base URL of the web app — used to build email verification / reset links.
FRONTEND_URL=https://dpatro.vercel.app

# ─── Email (SMTP) — needed for verification + password-reset emails ─────────────
# Leave SMTP_HOST unset to disable real sending (links are written to the log so
# you can still test the flows in development).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com
# SMTP_FROM_NAME=Dhakal Patro
# SMTP_USE_TLS=true
